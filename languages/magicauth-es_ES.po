msgid "Brand URL"
msgstr "URL de marca"

#: includes/Admin/Settings.php:682
msgid "Opens in a new tab. Must start with http:// or https://."
msgstr "Se abre en una pestaña nueva. Debe empezar por http:// o https://."

#: includes/Admin/Settings.php:695
msgid "Brand favicon"
msgstr "Favicon de marca"

#: includes/Admin/Settings.php:696
msgid "Square 32×32 or larger. PNG, JPG, WebP, or SVG."
msgstr "Cuadrado de 32×32 o mayor. PNG, JPG, WebP o SVG."

#: includes/Admin/Settings.php:706
msgid "Credit label"
msgstr "Etiqueta de crédito"

#: includes/Admin/Settings.php:707
msgid "Text shown before the brand name. Leave blank for the default (\"Built by\")."
msgstr "Texto que se muestra antes del nombre de marca. Déjelo en blanco para el valor predeterminado (\"Creado por\")."

#: includes/Admin/Settings.php:710
msgid "Built by"
msgstr "Creado por"

#: includes/Admin/Settings.php:722
msgid "\"Sign in with password\" link"
msgstr "Enlace \"Iniciar sesión con contraseña\""

#: includes/Admin/Settings.php:723
msgid "Always-visible recovery link on every form. Only disable this if you have already disabled WordPress password authentication site-wide."
msgstr "Enlace de recuperación siempre visible en todos los formularios. Desactívelo solo si ya ha desactivado la autenticación por contraseña de WordPress en todo el sitio."

#: includes/Admin/Settings.php:740
msgid "Per-IP window (hours)"
msgstr "Ventana por IP (horas)"

#: includes/Admin/Settings.php:741
msgid "Per-IP max requests"
msgstr "Solicitudes máximas por IP"

#: includes/Admin/Settings.php:742
