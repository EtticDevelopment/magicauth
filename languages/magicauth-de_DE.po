msgid "Brand name"
msgstr "Markenname"

#: includes/Admin/Settings.php:666
msgid "Shown bold in the credit line."
msgstr "Wird fett in der Credit-Zeile angezeigt."

#: includes/Admin/Settings.php:669
msgid "Acme Studio"
msgstr ""

#: includes/Admin/Settings.php:681
msgid "Brand URL"
msgstr "Marken-URL"

#: includes/Admin/Settings.php:682
msgid "Opens in a new tab. Must start with http:// or https://."
msgstr "Öffnet in einem neuen Tab. Muss mit http:// oder https:// beginnen."

#: includes/Admin/Settings.php:695
msgid "Brand favicon"
msgstr "Marken-Favicon"

#: includes/Admin/Settings.php:696
msgid "Square 32×32 or larger. PNG, JPG, WebP, or SVG."
msgstr "Quadratisch 32×32 oder größer. PNG, JPG, WebP oder SVG."

#: includes/Admin/Settings.php:706
msgid "Credit label"
msgstr "Credit-Bezeichnung"

#: includes/Admin/Settings.php:707
msgid "Text shown before the brand name. Leave blank for the default (\"Built by\")."
msgstr "Text, der vor dem Markennamen angezeigt wird. Leer lassen für den Standard (\"Erstellt von\")."

#: includes/Admin/Settings.php:710
msgid "Built by"
msgstr "Erstellt von"

#: includes/Admin/Settings.php:722
msgid "\"Sign in with password\" link"
msgstr "Link \"Mit Passwort anmelden\""

#: includes/Admin/Settings.php:723
msgid "Always-visible recovery link on every form. Only disable this if you have already disabled WordPress password authentication site-wide."
msgstr "Immer sichtbarer Wiederherstellungslink auf jedem Formular. Deaktivieren Sie dies nur, wenn Sie die WordPress-Passwort-Authentifizierung bereits site-weit deaktiviert haben."

#: includes/Admin/Settings.php:740
msgid "Per-IP window (hours)"
msgstr "Zeitfenster pro IP (Stunden)"

#: includes/Admin/Settings.php:741
msgid "Per-IP max requests"
msgstr "Max. Anfragen pro IP"

#: includes/Admin/Settings.php:742
msgid "Per-IP code window (hours)"
msgstr "Code-Zeitfenster pro IP (Stunden)"

#: includes/Admin/Settings.php:743
msgid "Per-IP max code attempts"
msgstr "Max. Code-Versuche pro IP"

#: includes/Admin/Settings.php:748
msgid "Per-email cooldown"
msgstr "Abklingzeit pro E-Mail"

#: includes/Admin/Settings.php:749
msgid "Seconds between consecutive link requests for the same email. 0 disables. Default 60. Replaced the per-email hard cap in v1.3.7. That cap was a DoS primitive any IP could weaponize against any victim email."
msgstr "Sekunden zwischen aufeinanderfolgenden Link-Anfragen für dieselbe E-Mail. 0 deaktiviert. Standard 60. Ersetzte das harte Limit pro E-Mail in v1.3.7. Dieses Limit war ein DoS-Primitiv, das jede IP gegen jede Opfer-E-Mail einsetzen konnte."

#: includes/Admin/Settings.php:753
msgid "seconds"
msgstr "Sekunden"

