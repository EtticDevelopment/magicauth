# =====================================================================
# MagicAuth .gitignore
#
# The plugin ships from the repo root. Distribution artifacts (the
# trimmed mirror + zips) live under build/ and never enter git history.
# =====================================================================

# --- Internal-only working tree -------------------------------------
# Planning docs, research notes, pentest reports, and design mockups.
# Never ship publicly.
_dev/
CLAUDE.md
.claude/

# --- Dependencies ----------------------------------------------------
# vendor/ is regenerated by `composer install` (dev) or by the build
# step (`composer install --no-dev` into build/magicauth/vendor).
#
# composer.lock is intentionally untracked: the plugin has no runtime
# `require` constraints, only dev tooling pins. If you ever add a
# runtime dependency, flip this and commit the lock so installs stay
# reproducible across machines.
vendor/
composer.lock
auth.json

# Node (only relevant if a frontend toolchain lands later). Keep lock
# files (package-lock.json / yarn.lock / pnpm-lock.yaml) tracked.
node_modules/

# --- Build & distribution -------------------------------------------
build/
*.zip
*.tar.gz

# --- PHP tooling caches ---------------------------------------------
.phpunit.cache/
.phpunit.result.cache
.phpcs-cache
.php-cs-fixer.cache
.phpstan.cache/

# --- Local config overrides (committed *.dist defaults stay) --------
# PHPUnit/PHPCS/PHPStan all prefer the bare filename over .dist when
# present, so contributors can shadow the defaults locally.
phpcs.xml
phpstan.neon
phpunit.xml
wp-tests-config.php

# --- Coverage reports -----------------------------------------------
coverage/
clover.xml
coverage.xml
.phpunit.coverage*

# --- Logs and dumps -------------------------------------------------
*.log
error_log
*.sql

# --- Secrets and local env ------------------------------------------
.env
.env.*
!.env.example
security/

# --- Translation artifacts ------------------------------------------
# Compiled .mo files only. Source .po / .pot stay tracked.
languages/*.mo

# --- Editors / IDEs -------------------------------------------------
.idea/
.vscode/
.fleet/
.zed/
.history/
*.sublime-project
*.sublime-workspace
nbproject/
*.swp
*.swo
*~

# --- macOS junk -----------------------------------------------------
.DS_Store
._*
.AppleDouble
.LSOverride
Icon?

# --- Windows junk ---------------------------------------------------
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# --- Linux junk -----------------------------------------------------
.fuse_hidden*
.directory
.Trash-*
.nfs*
